# URL e chaves do projeto Supabase (Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Service role key: NUNCA expor ao cliente, usada apenas em código server-only
# (ex.: convite/criação de usuários em /configuracoes/usuarios).
SUPABASE_SERVICE_ROLE_KEY=eyJ...
